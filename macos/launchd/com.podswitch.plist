<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.podswitch</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Applications/PodSwitch.app/Contents/MacOS/PodSwitch</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>ProcessType</key>
    <string>Interactive</string>

    <key>StandardOutPath</key>
    <string>/tmp/com.podswitch.out.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/com.podswitch.err.log</string>
</dict>
</plist>
